APP_NAME="IP Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ip_service_db
DB_USERNAME=ip_user
DB_PASSWORD=ip_secret

CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# Shared HMAC secret — must match auth-service JWT_SECRET exactly
# Generate with: openssl rand -base64 64
JWT_SECRET=
JWT_TTL=1440
