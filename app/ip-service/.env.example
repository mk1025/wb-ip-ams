APP_NAME="IP Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ip_service_db
DB_USERNAME=ip_user
DB_PASSWORD=ip_secret

CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# RS256 public key only — IP Service verifies tokens but cannot issue them.
# This service must NEVER have the private key. Set JWT_PUBLIC_KEY to the
# same base64-encoded public key used by the auth-service.
#
# Encode: JWT_PUBLIC_KEY=$(base64 -w 0 public.pem)
JWT_ALGO=RS256
JWT_PUBLIC_KEY=
JWT_TTL=1440

# Shared secret validated on internal service-to-service routes
# Generate with: openssl rand -base64 32
INTERNAL_SECRET=
