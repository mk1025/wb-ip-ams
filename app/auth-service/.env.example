APP_NAME="Auth Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=auth_service_db
DB_USERNAME=auth_user
DB_PASSWORD=auth_secret

CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# RS256 asymmetric JWT signing — Auth Service holds the private key and signs tokens.
# The IP Service only receives the public key and can verify but never forge tokens.
#
# 1. Generate a key pair:
#    openssl genrsa -out private.pem 4096
#    openssl rsa -in private.pem -pubout -out public.pem
#
# 2. Base64-encode each file (single-line, no newlines):
#    JWT_PRIVATE_KEY=$(base64 -w 0 private.pem)
#    JWT_PUBLIC_KEY=$(base64 -w 0 public.pem)
#
# Keep private.pem secret — delete it after encoding or store in a vault.
JWT_ALGO=RS256
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_TTL=1440

# Internal URL of the IP service
IP_SERVICE_URL=http://localhost:8001

# Shared secret sent as X-Internal-Secret header on service-to-service calls
# Generate with: openssl rand -base64 32
INTERNAL_SECRET=
