# Auth Service
MYSQL_AUTH_ROOT_PASSWORD=root
AUTH_DB_USERNAME=auth_user
AUTH_DB_PASSWORD=auth_secret
AUTH_DB_DATABASE=auth_service_db
AUTH_DB_PORT=3307

# IP Service
MYSQL_IP_ROOT_PASSWORD=root
IP_DB_USERNAME=ip_user
IP_DB_PASSWORD=ip_secret
IP_DB_DATABASE=ip_service_db
IP_DB_PORT=3308

# Gateway
GATEWAY_PORT=3000
# Must match GATEWAY_PORT — used by docker-compose to set the app's own URL.
GATEWAY_APP_URL=http://localhost:3000

# JWT
# openssl genrsa -out private.pem 4096
# openssl rsa -in private.pem -pubout -out public.pem
# JWT_PRIVATE_KEY=$(base64 -w 0 private.pem)
# JWT_PUBLIC_KEY=$(base64 -w 0 public.pem)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_TTL=1440

# internal secret
# openssl rand -base64 32
INTERNAL_SECRET=change-me-generate-with-openssl-rand-base64-32

# Frontend
VITE_API_BASE_URL=http://localhost:3000/api
FRONTEND_PORT=80
