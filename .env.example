# Auth Service
MYSQL_AUTH_ROOT_PASSWORD=root
AUTH_DB_USERNAME=auth_user
AUTH_DB_PASSWORD=auth_secret

# IP Service
MYSQL_IP_ROOT_PASSWORD=root
IP_DB_USERNAME=ip_user
IP_DB_PASSWORD=ip_secret

# JWT
# Both auth-service and ip-service MUST share the same secret.
# Generate a strong one with: openssl rand -base64 64
JWT_SECRET=change-me-generate-with-openssl-rand-base64-64

JWT_TTL=1440

# Internal service-to-service secret (auth-service → ip-service sync)
# Generate with: openssl rand -base64 32
INTERNAL_SECRET=change-me-internal-secret

# Frontend
VITE_API_BASE_URL=http://localhost:3000/api
